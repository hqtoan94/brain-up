#!/usr/bin/env python3
"""Add a `type:` field to every content note's frontmatter that lacks one.

Idempotent migration. The type is derived from the note's folder — see
FOLDER_TYPES, RESOURCE_SUBFOLDER_TYPES, and LEGACY_TOPLEVEL_TYPES in brainlib.py.

Usage: scripts/add-types [--dry-run]
"""

import sys

from brainlib import content_notes, note_type, read_note


def main():
    dry_run = "--dry-run" in sys.argv
    added, skipped_no_fm, already = [], [], 0

    for path, folder in content_notes():
        inferred = note_type(path, folder)
        if inferred is None:
            continue
        text, meta, _ = read_note(path)
        if meta is None:
            skipped_no_fm.append(path)
            continue
        if "type" in meta:
            already += 1
            continue
        new_text = text.replace("---\n", f"---\ntype: {inferred}\n", 1)
        if not dry_run:
            path.write_text(new_text, encoding="utf-8")
        added.append(path)

    print(f"type added: {len(added)}  already typed: {already}  no frontmatter (skipped): {len(skipped_no_fm)}")
    for p in skipped_no_fm:
        print(f"  no frontmatter: {p}")
    if dry_run:
        print("(dry run — nothing written)")


if __name__ == "__main__":
    main()

#!/usr/bin/env python3
"""Weekly digest — the push half of resurfacing (requirement R2).

Builds a markdown digest of: notes changed in the window, inbox items waiting,
and stale active projects/areas. No AI, no network — CI mails it or opens an
issue with it; a human can also just run it before a weekly review.

Usage: scripts/digest [--days 7]
Prints markdown to stdout.
"""

import argparse
import signal
import subprocess
from datetime import date

signal.signal(signal.SIGPIPE, signal.SIG_DFL)  # exit quietly when piped to head

from brainlib import VAULT_ROOT, inbox_dir


def recent_changes(days):
    out = subprocess.run(
        ["git", "log", f"--since={days} days ago", "--name-only", "--pretty=format:"],
        cwd=VAULT_ROOT, capture_output=True, text=True, check=True,
    ).stdout
    files = sorted({f for f in out.splitlines() if f.startswith("brain/") and f.endswith(".md")
                    and not f.endswith(("README.md", "index.md"))})
    return files


def freshness_lines():
    out = subprocess.run(
        ["python3", "scripts/freshness"], cwd=VAULT_ROOT, capture_output=True, text=True,
    ).stdout.splitlines()
    return [l for l in out if l and not l.startswith("freshness:")]


def main():
    ap = argparse.ArgumentParser()
    ap.add_argument("--days", type=int, default=7)
    args = ap.parse_args()

    changed = recent_changes(args.days)
    inbox_root = inbox_dir()
    inbox = sorted(p.name for p in inbox_root.glob("*.md") if p.name != "README.md") if inbox_root.is_dir() else []
    stale = freshness_lines()

    print(f"# Brain digest — {date.today().isoformat()}")
    print()
    print(f"## Changed in the last {args.days} days ({len(changed)})")
    print()
    for f in changed or ["*nothing — a quiet week*"]:
        print(f"* {f}")
    print()
    print(f"## Inbox waiting ({len(inbox)})")
    print()
    for f in inbox or ["*inbox is empty*"]:
        print(f"* {f}")
    print()
    print(f"## Going stale ({len(stale)})")
    print()
    if stale:
        print("```")
        print("\n".join(stale))
        print("```")
    else:
        print("*nothing stale*")
    print()
    print("*Generated by `scripts/digest` — run `scripts/freshness` or process the inbox to act on this.*")


if __name__ == "__main__":
    main()

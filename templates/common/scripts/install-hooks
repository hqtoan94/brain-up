#!/bin/sh
# Point git at the tracked hooks so every commit is linted locally.
# Run once per clone (brain-up should call this during install/sync).

set -e
cd "$(git rev-parse --show-toplevel)"
chmod +x .githooks/*
git config core.hooksPath .githooks
echo "hooks installed: core.hooksPath -> .githooks (pre-commit = regen-indexes + lint)"

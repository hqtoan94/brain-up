#!/usr/bin/env python3
"""Regenerate the root index.md and per-folder brain/<folder>/index.md files.

Index files are GENERATED artifacts (progressive-disclosure maps for humans
and agents). They are never edited by hand — rerun this script instead.
Run after adding, renaming, or moving notes; CI may also run it.

Usage: scripts/regen-indexes
"""

from brainlib import (
    BRAIN,
    COMPANY_INDEXED_FOLDERS,
    GENERATED_MARKER,
    RESOURCE_INDEXED_SUBFOLDERS,
    RESOURCE_SUBFOLDERS,
    VAULT_ROOT,
    brain_type,
    indexed_folders,
    read_note,
)


def note_entries(folder, subfolder=None):
    """[(sort_key, line)] for every content note in brain/<folder>[/subfolder]."""
    entries = []
    if subfolder:
        root = BRAIN / "resources" / subfolder
    else:
        root = BRAIN / folder
    if not root.is_dir():
        return entries
    for path in sorted(root.rglob("*.md")):
        if path.name in {"README.md", "index.md"} or "templates" in path.parts:
            continue
        if folder == "resources" and not subfolder:
            rel_to_resources = path.relative_to(root)
            if rel_to_resources.parts and rel_to_resources.parts[0] in RESOURCE_SUBFOLDERS:
                continue
        _, meta, _ = read_note(path)
        meta = meta or {}
        title = meta.get("title") or path.stem
        rel = path.relative_to(root).as_posix()
        detail = []
        if meta.get("maturity"):
            detail.append(meta["maturity"])
        if meta.get("status"):
            detail.append(meta["status"])
        suffix = f" — {', '.join(detail)}" if detail else ""
        entries.append((str(title).lower(), f"* [{title}]({rel}){suffix}"))
    return entries


def write_folder_index(folder, subfolder=None):
    if subfolder:
        root = BRAIN / "resources" / subfolder
        label = f"resources/{subfolder}"
    else:
        root = BRAIN / folder
        label = folder
    if not root.is_dir():
        return 0
    entries = note_entries(folder, subfolder=subfolder)
    if folder == "journal" or subfolder == "journal":
        entries.sort(key=lambda e: e[0], reverse=True)
    else:
        entries.sort(key=lambda e: e[0])
    lines = [
        f"# {label} — index",
        "",
        GENERATED_MARKER,
        "",
        f"{len(entries)} notes. See [README.md](README.md) for what belongs here.",
        "",
        *[line for _, line in entries],
        "",
    ]
    (root / "index.md").write_text("\n".join(lines), encoding="utf-8")
    return len(entries)


def write_root_index(counts, sub_counts):
    lines = [
        "# Brain — map",
        "",
        GENERATED_MARKER,
        "",
        "Start here. The operating contract is [AGENTS.md](AGENTS.md); the quick",
        "reference is [CHEATSHEET.md](CHEATSHEET.md).",
        "",
        "| Folder | Notes | What it holds |",
        "|---|---|---|",
    ]
    blurbs = {
        "projects": "active, goal-bound efforts (PARA)",
        "areas": "ongoing responsibilities (PARA)",
        "resources": "atomic + distilled knowledge notes",
        "archive": "done / inactive items",
        "journal": "one note per day",
        "people": "contacts and relationships",
        "meetings": "meeting notes",
        "decisions": "decision records",
        "1on1s": "1:1 notes by person",
    }
    sub_blurbs = {
        "goals": "vision and yearly outcomes (reference)",
        "journal": "one note per day (reference)",
        "people": "contacts and relationships (reference)",
        "career": "portable, anonymized career record (reference)",
    }
    for folder in indexed_folders():
        lines.append(
            f"| [{folder}](brain/{folder}/index.md) | {counts.get(folder, 0)} | {blurbs[folder]} |"
        )
    if brain_type() == "personal":
        for sub in RESOURCE_INDEXED_SUBFOLDERS:
            lines.append(
                f"| [resources/{sub}](brain/resources/{sub}/index.md) | {sub_counts.get(sub, 0)} | {sub_blurbs[sub]} |"
            )
    lines += [""]
    (VAULT_ROOT / "index.md").write_text("\n".join(lines), encoding="utf-8")


def main():
    counts = {}
    for folder in indexed_folders():
        counts[folder] = write_folder_index(folder)
        print(f"brain/{folder}/index.md — {counts[folder]} entries")
    sub_counts = {}
    if brain_type() == "personal":
        for sub in RESOURCE_INDEXED_SUBFOLDERS:
            sub_counts[sub] = write_folder_index("resources", subfolder=sub)
            print(f"brain/resources/{sub}/index.md — {sub_counts[sub]} entries")
    elif brain_type() == "company":
        for folder in COMPANY_INDEXED_FOLDERS:
            if folder in {"journal", "people"}:
                counts[folder] = write_folder_index(folder)
                print(f"brain/{folder}/index.md — {counts[folder]} entries")
    write_root_index(counts, sub_counts)
    print("index.md — root map")


if __name__ == "__main__":
    main()
